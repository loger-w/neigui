+/** 最新非 null iv_bid 在全窗非 null iv_bid 的分位(0-100,<= 口徑對齊 backend)。 */
+export function computeIvPercentile(series: WarrantIvPoint[]): number | null {
+  const values = series.map((p) => p.iv_bid).filter((v): v is number => v != null);
